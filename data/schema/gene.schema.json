{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AMRxref gene record",
  "type": "object",
  "required": ["aro_id", "canonical_name", "gene_family", "variant_type", "mappings"],
  "properties": {
    "aro_id": { "type": "string", "pattern": "^ARO:[0-9]+$" },
    "canonical_name": { "type": "string" },
    "gene_family": { "type": "string" },
    "preferred_label": { "type": "string" },
    "variant_type": {
      "type": "string",
      "enum": ["protein_coding", "rrna", "promoter", "regulatory_region"]
    },
    "drug_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["aro", "label"],
        "properties": {
          "aro": { "type": "string", "pattern": "^ARO:[0-9]+$" },
          "label": { "type": "string" },
          "chebi": { "type": "string" }
        }
      }
    },
    "mechanism": { "type": "string" },
    "mechanism_aro": { "type": "string" },
    "canonical_protein": {
      "type": "object",
      "properties": {
        "uniprot": { "type": "string" },
        "ncbi_protein": { "type": "string" },
        "length_aa": { "type": "integer" },
        "sha256_aa": { "type": "string" }
      }
    },
    "canonical_nucleotide": {
      "type": "object",
      "properties": {
        "ncbi_nuccore": { "type": "string" },
        "length_nt": { "type": "integer" },
        "sha256_nt": { "type": "string" }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["target_db", "target_id", "relation", "level", "quality"],
        "properties": {
          "target_db": {
            "type": "string",
            "enum": ["AMRFinderPlus", "ResFinder", "MEGARes", "CARD", "NCBI", "UniProt"]
          },
          "target_id": { "type": "string" },
          "relation": {
            "type": "string",
            "enum": ["skos:exactMatch", "skos:closeMatch", "skos:broadMatch", "skos:narrowMatch", "skos:relatedMatch"]
          },
          "level": {
            "type": "string",
            "enum": ["protein", "nucleotide"]
          },
          "evidence": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "value": { "type": "string" }
            }
          },
          "curator": { "type": "string" },
          "date": { "type": "string" },
          "quality": {
            "type": "string",
            "enum": ["gold", "silver", "bronze"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "literature_pmids": {
      "type": "array",
      "items": { "type": "integer" }
    }
  }
}
